{
  "expo": {
    "name": "FConline Ground",
    "slug": "fconline-ground",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fconlineground",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f3f5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fcoground.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f0f3f5"
      },
      "package": "com.fcoground.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/PretendardVariable.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Pretendard",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Pretendard-Thin.ttf",
                    "weight": 100
                  },
                  {
                    "path": "./assets/fonts/Pretendard-ExtraLight.ttf",
                    "weight": 200
                  },
                  {
                    "path": "./assets/fonts/Pretendard-Light.ttf",
                    "weight": 300
                  },
                  {
                    "path": "./assets/fonts/Pretendard-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Pretendard-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Pretendard-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/Pretendard-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Pretendard-ExtraBold.ttf",
                    "weight": 800
                  },
                  {
                    "path": "./assets/fonts/Pretendard-Black.ttf",
                    "weight": 900
                  }
                ]
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
